class Solution {
public:
    int compress(vector<char>& chars) {

        int n = chars.size();
        int index = 0; // write pointer
        int i = 0;     // read pointer

        while(i < n) {
            char currentChar = chars[i];
            int count = 0;

            while(i <n && chars[i] == currentChar) {
                count++;
                i++;
            }

            // Write character
            chars[index] = currentChar;
            index++;

            // Write count if > 1
            if(count > 1) {
                string cnt = to_string(count);

                for(char c : cnt) {
                    chars[index] = c;
                    index++;
                }
            }
        }
        return index;
    }
};