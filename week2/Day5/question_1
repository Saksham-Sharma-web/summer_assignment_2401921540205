class Solution {
public:
    vector<vector<string>> groupAnagrams(vector<string>& strs) {
        // hashmap + sorting
        unordered_map<string,vector<string>> mp;
        int n= strs.size();
        for(int i =0; i<n; i++){
            string s = strs[i]; 
            sort(s.begin(), s.end());
            mp[s].push_back(strs[i]);  // will not use .insert() fn as no other input with same key will be again pushed in map.
        }
        
        vector<vector<string>> ans;
        for(auto &it: mp){
           ans.push_back(it.second);
        }

        return ans;
    }

};